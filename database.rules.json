{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "$roomId.matches(/^[A-Z0-9]{6}$/)",
        ".write": "$roomId.matches(/^[A-Z0-9]{6}$/)",
        "code": {
          ".validate": "newData.isString() && newData.val() === $roomId"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing')"
        },
        "phase": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 4"
        },
        "round": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"
        },
        "maxUses": {
          ".validate": "newData.isNumber() && newData.val() === 5"
        },
        "totalUses": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 6"
        },
        "expired": {
          ".validate": "newData.isBoolean()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "players": {
          "$pid": {
            ".validate": "$pid === 'player1' || $pid === 'player2'",
            "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30" },
            "id":   { ".validate": "newData.isString() && newData.val().length <= 64" },
            "ready":{ ".validate": "newData.isBoolean()" },
            "$other": { ".validate": false }
          }
        },
        "answers": {
          "$pid": {
            ".validate": "$pid === 'player1' || $pid === 'player2'",
            "$phase": {
              ".validate": "$phase.matches(/^phase[1-4]$/)",
              "$round": {
                ".validate": "newData.isString() && newData.val().length <= 60"
              }
            }
          }
        },
        "roundSubmissions": {
          "$rk": {
            ".validate": "$rk.matches(/^p[1-4]_r[0-4]$/)",
            "$pid": {
              ".validate": "($pid === 'player1' || $pid === 'player2') && newData.isBoolean()"
            }
          }
        },
        "gameState": {
          ".validate": "newData.hasChild('event')"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
